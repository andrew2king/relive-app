# Database Configuration
DATABASE_URL="postgresql://relive:relive123@localhost:5432/relive_db"
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# AI Service API Keys
OPENAI_API_KEY="your-openai-api-key"
CLAUDE_API_KEY="your-claude-api-key"
GEMINI_API_KEY="your-gemini-api-key"

# AWS Configuration (for file storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="relive-files"

# Payment Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# WeChat Pay (for Chinese market)
WECHAT_PAY_APPID="your-wechat-appid"
WECHAT_PAY_MCH_ID="your-merchant-id"
WECHAT_PAY_API_KEY="your-wechat-api-key"

# Email Configuration
EMAIL_FROM="noreply@relive-app.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-password"

# Application Configuration
NODE_ENV="development"
PORT="8000"
AI_SERVICE_PORT="8001"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:8000"

# File Upload Configuration
MAX_FILE_SIZE="50000000"  # 50MB
UPLOAD_DIR="./uploads"
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,image/tiff"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# Session Configuration
SESSION_SECRET="your-session-secret-key"
SESSION_TIMEOUT="86400000"  # 24 hours

# Monitoring Configuration
SENTRY_DSN="your-sentry-dsn"
LOG_LEVEL="info"

# Feature Flags
ENABLE_USER_REGISTRATION="true"
ENABLE_SOCIAL_LOGIN="true"
ENABLE_REFERRAL_SYSTEM="true"
ENABLE_PAYMENT_SYSTEM="true"

# Third-party Integrations
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
WECHAT_APP_ID="your-wechat-app-id"
WECHAT_APP_SECRET="your-wechat-app-secret"

# CDN Configuration
CDN_URL="https://cdn.relive-app.com"
STATIC_FILES_URL="https://static.relive-app.com"

# Analytics
GOOGLE_ANALYTICS_ID="GA_MEASUREMENT_ID"
MIXPANEL_TOKEN="your-mixpanel-token"

# Error Tracking
BUGSNAG_API_KEY="your-bugsnag-api-key"

# Cache Configuration
CACHE_TTL="3600"  # 1 hour
REDIS_MAX_MEMORY="256mb"

# Worker Configuration
WORKER_CONCURRENCY="2"
QUEUE_NAME="relive-processing"

# Security Configuration
BCRYPT_ROUNDS="12"
PASSWORD_MIN_LENGTH="8"
MAX_LOGIN_ATTEMPTS="5"
ACCOUNT_LOCKOUT_TIME="900000"  # 15 minutes

# API Configuration
API_VERSION="v1"
API_PREFIX="/api"
API_TIMEOUT="30000"  # 30 seconds

# Development Configuration
DEBUG="false"
ENABLE_CORS="true"
CORS_ORIGIN="http://localhost:3000"

# Production Configuration (uncomment for production)
# NODE_ENV="production"
# DATABASE_URL="postgresql://prod_user:prod_password@prod_host:5432/relive_prod"
# REDIS_URL="rediss://prod_redis_url"
# FRONTEND_URL="https://relive-app.com"
# BACKEND_URL="https://api.relive-app.com"