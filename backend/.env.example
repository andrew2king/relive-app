# ===================================
# RELIVE APP - 环境配置模板文件
# ===================================
# 复制此文件为 .env 并填写实际配置值
# cp .env.example .env

# ===================================
# 服务器配置
# ===================================
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# ===================================
# AI API 配置 - 人物复活 (D-ID)
# ===================================
# 获取方式: https://www.d-id.com/ → 注册账户 → API Keys
DID_API_KEY=your_d_id_api_key_here

# ===================================
# AI API 配置 - 图生视频 (火山引擎即梦)
# ===================================
# 获取方式: https://console.volcengine.com/ → 访问控制 → 访问密钥
VOLC_ACCESSKEY=your_volc_access_key_here
VOLC_SECRETKEY=your_volc_secret_key_here

# ===================================
# AI API 配置 - 图像修复 (Replicate)
# ===================================
# 获取方式: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_replicate_api_token_here

# GFPGAN模型配置 (可选)
GFPGAN_MODEL_VERSION=tencentarc/gfpgan:9283608cc6b7be6b65a8e44983db012355fde4132009bf99d976b2f0896856a3
GFPGAN_SCALE=2
GFPGAN_VERSION=v1.4

# ===================================
# 云存储配置 (阿里云OSS)
# ===================================
# 获取方式: https://ram.console.aliyun.com/manage/ak → 创建AccessKey
OSS_ACCESS_KEY_ID=your_oss_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret_here
OSS_BUCKET=relive-photos
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou

# ===================================
# 可选配置 (根据需要启用)
# ===================================
# DATABASE_URL=postgresql://username:password@localhost:5432/relive_app
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=your-super-secret-jwt-key-here
# BCRYPT_SALT_ROUNDS=10
# LOG_LEVEL=info
# LOG_FILE=logs/relive-app.log
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
UPLOAD_TEMP_DIR=uploads/temp
PROCESSED_OUTPUT_DIR=uploads/processed
# API_RATE_LIMIT=100
# API_RATE_WINDOW=1
# ENABLE_MONITORING=false
# MONITORING_ENDPOINT=https://your-monitoring-service.com/api/metrics