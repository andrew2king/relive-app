{
  "name": "relive-app",
  "version": "1.0.0",
  "description": "RELIVE AI老照片复活平台",
  "main": "index.js",
  "scripts": {
    "install:all": "npm run install:frontend && npm run install:backend && npm run install:ai",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && npm install", 
    "install:ai": "cd ai-service && npm install",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ai\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev:ai": "cd ai-service && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint"
  },
  "workspaces": [
    "frontend",
    "backend", 
    "ai-service"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "lerna": "^7.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/company/relive-app.git"
  },
  "keywords": [
    "AI",
    "photo-restoration",
    "image-processing",
    "react",
    "nodejs"
  ],
  "author": "RELIVE Team",
  "license": "MIT"
}